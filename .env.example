# cTrader FIX API credentials. Copy this file to .env and fill in real values.
# .env is git-ignored — never commit your credentials.

# FIX host for your broker, e.g. h8.p.ctrader.com
CTRADER_HOST=abc.d.ctrader.com

# Full account string: <env>.<broker>.<login>, e.g. demo.yourbroker.1234567
CTRADER_SENDER_COMP_ID=demo.yourbroker.1234567

# FIX API password you set on the cTrader platform
CTRADER_PASSWORD=YOUR_PASSWORD

# Account deposit currency (optional, defaults to USD)
CTRADER_CURRENCY=USD

# Safety switch: only "true" lets the example actually place orders
CTRADER_LIVE_TRADING=false
