# ─────────────────────────────────────────────────────────────────────────────
#  cTrader FIX API credentials
#
#  In cTrader:  Settings → FIX API.  You'll see two blocks like this:
#
#      Price Connection                  Trade Connection
#      ----------------                  ----------------
#      Host name:    demo-xx.c-trader.com   Host name:    demo-xx.c-trader.com
#      Port:         5211 / 5201            Port:         5212 / 5202
#      Password:     ********               Password:     ********
#      SenderCompID: demo.broker.1234567    SenderCompID: demo.broker.1234567
#      TargetCompID: cServer                TargetCompID: cServer
#      SenderSubID:  QUOTE                  SenderSubID:  TRADE
#
#  Both blocks share the same Host name, Password and SenderCompID — just copy
#  those three values below. Ports, TargetCompID and SenderSubID are fixed by the
#  protocol and handled for you, so you don't need to set them.
#
#  Copy this file to .env and paste your values. .env is git-ignored — never
#  commit it.
# ─────────────────────────────────────────────────────────────────────────────

# "Host name"  (same in both blocks)
CTRADER_HOST=demo-xx.p.c-trader.com

# "SenderCompID"  (your account, e.g. demo.broker.1234567)
CTRADER_SENDER_COMP_ID=demo.broker.1234567

# "Password"  (your FIX API / account password)
CTRADER_PASSWORD=

# ── App settings (not shown in the cTrader panel) ────────────────────────────

# Account deposit currency (defaults to USD)
CTRADER_CURRENCY=USD

# Safety switch: only "true" lets the example actually place orders
CTRADER_LIVE_TRADING=false
